# ─────────────────────────────────────────────────────────────────────────
# Estera CRM — Umgebungsvariablen
# Diese Datei ist die Vorlage. Zum Arbeiten kopieren nach `.env.local`
# (wird von Git ignoriert) und die Werte eintragen.
# ─────────────────────────────────────────────────────────────────────────

# Supabase – zu finden im Supabase-Dashboard unter:
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key: NUR serverseitig verwenden, NIE mit NEXT_PUBLIC_ prefixen
# und NIE ins Frontend geben. Wird u. a. für Admin-/Seed-Aufgaben gebraucht.
SUPABASE_SERVICE_ROLE_KEY=

# Basis-URL der App (für Auth-Redirects ab Phase 2).
# Lokal: http://localhost:3000  ·  Produktion: https://<deine-domain>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
